    "print(f\"{'='*10} 3 Clusters {'='*10}\")\n",
    "print(f\"Davies-Bouldin Index: {db_k3:.4f}\")\n",
    "print(df.groupby('cluster_k3')[grouping_cols].mean())\n",
    "\n",
    "print(f\"\\n{'='*10} 4 Clusters {'='*10}\")\n",
    "print(f\"Davies-Bouldin Index: {db_k4:.4f}\")\n",
